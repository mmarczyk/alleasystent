# ────────────────────────────────────────────────────────────────────────────
# AllEasystent — Environment Configuration
# Copy to .env and fill in your values. Never commit .env to version control.
# ────────────────────────────────────────────────────────────────────────────

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=16000

# ── Facebook Messenger ────────────────────────────────────────────────────────
# Get these from https://developers.facebook.com/ → your Messenger app
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_VERIFY_TOKEN=alleasystent_verify_token   # set the same in FB dashboard
FACEBOOK_APP_SECRET=

# ── Allegro ───────────────────────────────────────────────────────────────────
# Get from https://apps.developer.allegro.pl/ → create an app (Device flow)
ALLEGRO_CLIENT_ID=
ALLEGRO_CLIENT_SECRET=
ALLEGRO_REDIRECT_URI=http://localhost:8080/allegro/callback

# ── GCP ───────────────────────────────────────────────────────────────────────
# Leave blank to run fully locally (in-memory Firestore, no Pub/Sub)
GCP_PROJECT_ID=
GCP_REGION=europe-central2

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_BACKEND=chromadb          # chromadb | vertex_ai
EMBEDDING_BACKEND=local       # local | vertex_ai
CHROMADB_PATH=./data/chromadb
RAG_TOP_K=5

# For Vertex AI (production):
# VERTEX_AI_INDEX_ENDPOINT=projects/.../locations/.../indexEndpoints/...
# VERTEX_AI_INDEX_ID=...

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development           # development | production
LOG_LEVEL=INFO
PORT=8080
